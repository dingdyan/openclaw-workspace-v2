实现功能:
   地图复活时删除'九尾狐变身'增加'九尾狐酒母'

   //已验证
******************************************************************************}

procedure OnRegen(uSource, curTcik: integer); //地图复活 重置
begin
  MapDelmonster('长城以南', '九尾狐变身'); //删除九尾狐变身
  if MapFindnpc('长城以南', '九尾狐酒母', 'all') <= 0 then //查找九尾狐酒母 失败
    MapAddnpc('长城以南', '九尾狐酒母', 127, 328, 1, 4, '', 1, 0);
end;

